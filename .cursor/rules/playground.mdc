    { type: 'group', label: '样式' },
    { type: 'slider', key: 'opacity', label: '透明度', min: 0, max: 1, step: 0.05, defaultValue: 1 },
    { type: 'slider', key: 'brightness', label: '亮度', min: -1, max: 1, step: 0.05, defaultValue: 0 },
    { type: 'slider', key: 'contrast', label: '对比度', min: -1, max: 1, step: 0.05, defaultValue: 0 },
