## Zustand Stores

### sceneStore.ts

```typescript
interface SceneState {
  /** 当前激活的场景 ID */
  activeSceneId: string;
  /** 场景配置值（key-value，ConfigPanel 修改后写入） */
  configValues: Record<string, any>;
  /** 引擎实例引用（不序列化） */
  engineRef: any | null;

  setActiveScene: (id: string) => void;
  setConfigValue: (key: string, value: any) => void;
  resetConfig: () => void;
  setEngineRef: (ref: any) => void;
}
```

### devtoolsStore.ts

```typescript
interface DevToolsState {
  /** 底部面板是否展开 */
  isBottomPanelOpen: boolean;
  /** 底部面板当前 Tab */
  bottomTab: 'console' | 'performance' | 'tiles' | 'shaders';
  /** 日志数组（最多保留 1000 条） */
  logs: LogEntry[];
  /** 性能数据环形缓冲（最近 60 个采样） */
  perfSamples: PerfSample[];
  /** 选中的瓦片 */
  selectedTile: TileDebugInfo | null;
  /** 选中的 Shader 变体 */
  selectedShaderVariant: string | null;
  /** 左面板是否折叠 */
  isLeftPanelCollapsed: boolean;
  /** 右面板是否折叠 */
  isRightPanelCollapsed: boolean;
  /** 当前主题 */
  theme: 'dark' | 'light';

  toggleBottomPanel: () => void;
  setBottomTab: (tab: string) => void;
  pushLog: (entry: LogEntry) => void;
  clearLogs: () => void;
  pushPerfSample: (sample: PerfSample) => void;
  setSelectedTile: (tile: TileDebugInfo | null) => void;
  setSelectedShaderVariant: (key: string | null) => void;
  toggleLeftPanel: () => void;
  toggleRightPanel: () => void;
  toggleTheme: () => void;
}

interface LogEntry {
  id: number;
  level: 'info' | 'warn' | 'error' | 'perf';
  timestamp: number;
  message: string;
  context?: Record<string, any>;
  suggestion?: string;
  docUrl?: string;
}

interface PerfSample {
  timestamp: number;
  fps: number;
  updateMs: number;
  renderMs: number;
  postMs: number;
  idleMs: number;
  gpuMemory: { textures: number; buffers: number; pipelines: number; total: number; budget: number };
  drawCalls: number;
  triangles: number;
  instances: number;
  tilesLoaded: number;
  tilesLoading: number;
  tilesCached: number;
}

interface TileDebugInfo {
  coord: string;
  state: 'loaded' | 'loading' | 'cached' | 'failed';
  source: string;
  loadTimeMs: number;
  decodeTimeMs: number;
  gpuBytes: number;
  featureCount: number;
  triangleCount: number;
  lodLevel: number;
  sse: number;
}
```

