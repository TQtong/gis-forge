## Zustand Stores（8 个）

### mapStore.ts
```typescript
interface MapState {
  center: [number, number];
  zoom: number;
  bearing: number;
  pitch: number;
  mode: '2d' | '25d' | 'globe';
  activeTool: 'pan' | 'select-click' | 'select-box' | 'select-lasso'
    | 'draw-point' | 'draw-line' | 'draw-polygon' | 'draw-rect' | 'draw-circle' | 'draw-freehand'
    | 'measure-distance' | 'measure-area' | 'measure-profile';
  engineRef: any | null;
}
```

### layerStore.ts
```typescript
interface LayerState {
  groups: LayerGroup[];              // { id, name, layers: LayerConfig[], collapsed }
  selectedLayerId: string | null;    // 右侧样式 Tab 关联的图层
}
// LayerConfig: { id, name, type, source, visible, opacity, paint, layout, filter, minzoom, maxzoom }
```

### selectionStore.ts
```typescript
interface SelectionState {
  selectedFeatures: Feature[];
  hoveredFeature: Feature | null;    // Popup 用
}
```

### annotationStore.ts
```typescript
interface AnnotationState {
  bookmarks: Bookmark[];             // { id, name, center, zoom, bearing, pitch, layers, mode }
  annotations: Annotation[];         // { id, type, geometry, label, style }
}
```

### historyStore.ts
```typescript
interface HistoryState {
  undoStack: HistoryEntry[];         // { type, description, data, timestamp }
  redoStack: HistoryEntry[];
}
```

### analysisStore.ts
```typescript
interface AnalysisState {
  activeAnalysis: string | null;
  progress: number;
  isRunning: boolean;
}
