### uiStore.ts
```typescript
interface UIState {
  theme: 'dark' | 'light';
  leftPanelCollapsed: boolean;
  rightPanelCollapsed: boolean;
  rightPanelTab: 'properties' | 'style' | 'legend';
  splitViewEnabled: boolean;
  splitViewMode: 'side-by-side' | 'slider';
